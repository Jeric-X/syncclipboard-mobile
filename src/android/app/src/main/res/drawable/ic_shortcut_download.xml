<?xml version="1.0" encoding="utf-8"?>
<!-- Shortcut icon for "Download clipboard"
     Uses a colored circular background + white arrow so it looks good
     on any launcher background. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Colored background circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1976D2" />
        </shape>
    </item>

    <!-- Download arrow (same path as ic_tile_download, inset to leave padding) -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M4,6v2h16V6H4zM12,20l6,-6h-4v-4H10v4H6L12,20z" />
        </vector>
    </item>

</layer-list>
