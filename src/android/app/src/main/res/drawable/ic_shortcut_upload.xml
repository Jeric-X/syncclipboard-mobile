<?xml version="1.0" encoding="utf-8"?>
<!-- Shortcut icon for "Upload clipboard"
     Uses a colored circular background + white arrow so it looks good
     on any launcher background. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Colored background circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#388E3C" />
        </shape>
    </item>

    <!-- Upload arrow (same path as ic_tile_upload, inset to leave padding) -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M4,16v2h16v-2H4zM12,4l-6,6h4v4h4v-4h4L12,4z" />
        </vector>
    </item>

</layer-list>
